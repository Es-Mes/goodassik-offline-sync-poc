{
    "name": "local-api-tests",
    "version": "1.0.0",
    "description": "Tests for Local API",
    "scripts": {
        "test": "jest --runInBand --detectOpenHandles --forceExit",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "jest": {
        "testEnvironment": "node",
        "coveragePathIgnorePatterns": [
            "/node_modules/"
        ],
        "testTimeout": 10000,
        "verbose": true
    },
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "compression": "^1.7.4",
        "multer": "^1.4.5-lts.1",
        "uuid": "^9.0.0",
        "better-sqlite3": "^9.2.2"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "supertest": "^6.3.3"
    }
}